# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/admissions_flow

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# Default admin (created by `npm run seed:admin`)
DEFAULT_ADMIN_EMAIL=admin@school.ru
DEFAULT_ADMIN_PASSWORD=admin12345
DEFAULT_ADMIN_NAME=Администратор

# Whisper (OpenAI) — optional, enables Speech-to-Text on Stage 0 call log
OPENAI_API_KEY=
